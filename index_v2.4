<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>比价程序 - 云同步版 v5.0</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <style>
        :root { --bg: #F5EFE6; --nav: #241408; --accent: #7A4F2D; --text: #2E1A0A; --sub: #907060; --border: #E2D0BC; --white: #FFFCF8; --star: #F5A623; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { margin: 0; background: var(--bg); color: var(--text); font-family: -apple-system, sans-serif; display: flex; flex-direction: column; height: 100vh; }
        
        header { background: var(--nav); padding: 40px 20px 20px; color: white; flex-shrink: 0; }
        .nav-title { font-size: 24px; font-weight: bold; margin-bottom: 5px; }
        .status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #ccc; margin-right: 5px; }
        .status-dot.online { background: #4caf50; }
        .status-text { font-size: 12px; color: #aaa; }

        main { flex: 1; overflow-y: auto; padding: 15px; }
        .group-card { background: var(--white); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 12px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        
        .group-header { padding: 15px; background: #faf4ed; border-bottom: 1px solid var(--border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
        .group-title-area { display: flex; flex-direction: column; }
        .group-title { font-weight: bold; font-size: 16px; display: flex; align-items: center; gap: 8px; }
        .group-stats { font-size: 11px; color: var(--sub); margin-top: 4px; display: flex; gap: 10px; }
        .stats-highlight { color: #C06840; font-weight: bold; }
        .arrow { font-size: 12px; color: #999; transition: transform 0.3s; }
        .arrow.collapsed { transform: rotate(-90deg); }

        .item-list { transition: all 0.3s ease-in-out; }
        .item-list.hidden { display: none; }
        .item-row { padding: 12px 15px; border-bottom: 1px dashed #eee; display: flex; justify-content: space-between; align-items: center; }
        .item-row:last-child { border-bottom: none; }
        .item-row.is-starred { background: #fffcf2; } 
        
        .item-main { flex: 1; }
        .channel-name { font-weight: bold; display: flex; align-items: center; gap: 6px; }
        .star-icon { color: #ccc; font-size: 18px; cursor: pointer; transition: 0.2s; user-select: none;}
        .star-icon.active { color: var(--star); }
        
        .price-box { text-align: right; }
        .unit-price { font-size: 16px; font-weight: bold; color: var(--accent); }
        .sub-text { font-size: 12px; color: var(--sub); margin-top: 4px; }
        .remark-text { font-size: 11px; color: #a88a78; background: #fdfaf7; padding: 4px 6px; border-radius: 4px; margin-top: 6px; display: inline-block; border: 1px solid #f0e6da; }
        
        .action-btns { display: flex; gap: 6px; margin-top: 8px; justify-content: flex-end; }
        .edit-btn { color: #4A7A50; font-size: 12px; padding: 4px 12px; background: #e8f0e9; border-radius: 4px; border: none; cursor: pointer; }

        footer { padding: 15px 20px 30px; background: var(--bg); border-top: 1px solid var(--border); }
        .add-btn { background: var(--accent); color: white; width: 100%; padding: 15px; border-radius: 8px; font-size: 16px; font-weight: bold; border: none; cursor: pointer;}
        
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 100; align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .form-card { background: var(--white); width: 92%; max-width: 400px; padding: 20px; border-radius: 12px; max-height: 90vh; overflow-y: auto;}
        input, select { width: 100%; background: var(--bg); border: 1px solid var(--border); padding: 12px; border-radius: 6px; margin-bottom: 10px; font-size: 15px; outline: none; }
        
        .btn-group { display: flex; gap: 10px; margin-top: 10px; }
        .btn-group button { flex: 1; padding: 12px; border-radius: 6px; border: none; font-weight: bold; font-size: 15px; cursor: pointer; }
        .btn-del-record { background: #fff1f0; color: #d9363e; margin-top: 15px; width: 100%; padding: 12px; border-radius: 6px; border: 1px solid #ffccc7; font-weight: bold; display: none; cursor: pointer;}
    </style>
</head>
<body>

<header>
    <div class="nav-title">比价程序</div>
    <div>
        <span id="statusDot" class="status-dot"></span>
        <span id="statusText" class="status-text">正在连接云端...</span>
    </div>
</header>

<main id="recordList"></main>

<footer>
    <button class="add-btn" onclick="openModal()">＋ 新增记录</button>
</footer>

<div class="modal" id="formModal">
    <div class="form-card">
        <div id="modalTitle" style="font-weight:bold; margin-bottom:15px; font-size:18px; border-left:4px solid var(--accent); padding-left:8px;">新增购买</div>
        
        <input type="text" id="f-name" placeholder="一级分类/商品名称 (如: 桶装水)" oninput="updateSuggestions()" list="name-list">
        <datalist id="name-list"></datalist>

        <div style="display:flex; gap:10px; margin-bottom:10px;">
            <input type="text" id="f-brand" placeholder="品牌 (选填)" list="brand-list" style="flex:1; margin-bottom:0;">
            <datalist id="brand-list"></datalist>
            
            <input type="text" id="f-model" placeholder="型号 (选填,如纯净水)" list="model-list" style="flex:1; margin-bottom:0;">
            <datalist id="model-list"></datalist>
        </div>
        
        <div style="display:flex; gap:10px; margin-bottom:10px;">
            <input type="number" id="f-specNum" placeholder="单件容量/重量" style="flex:2; margin-bottom:0;">
            <select id="f-specUnit" style="flex:1; margin-bottom:0;">
                <option value="L">L (升)</option>
                <option value="ml">ml (毫升)</option>
                <option value="kg">kg (千克)</option>
                <option value="g">g (克)</option>
                <option value="件">件/个</option>
            </select>
        </div>

        <div style="display:flex; gap:10px; margin-bottom:10px;">
            <input type="number" id="f-totalPrice" placeholder="总金额 (元)" style="margin-bottom:0;">
            <input type="number" id="f-qty" placeholder="购买件数" value="1" style="margin-bottom:0;">
        </div>
        
        <input type="text" id="f-channel" placeholder="购买渠道 (如: 闪购)" list="channel-list">
        <datalist id="channel-list"></datalist>

        <input type="text" id="f-remark" placeholder="备注 (选填,如: 满2件起送)" style="background:#fffcf2;">
        
        <div class="btn-group">
            <button style="background:#eee; color:#666;" onclick="closeModal()">取消</button>
            <button style="background:var(--accent); color:white;" onclick="handleSave()">保存</button>
        </div>
        
        <button id="btn-delete" class="btn-del-record" onclick="deleteRecord()">删除此记录</button>
    </div>
</div>

<script>
    const SUPABASE_URL = 'https://csktstukwmuitvsjjzwd.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNza3RzdHVrd211aXR2c2pqendkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4NTcwNzYsImV4cCI6MjA5MDQzMzA3Nn0.fc-7q3Xmr1MtZR_NdiIxQ4f3QtbtLn_T1smJM8_INlE';
    const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    const GROUP_ID = 'my_family_2026';

    let allRecords = []; 
    let currentEditId = null; 
    let collapsedGroups = {};

    async function fetchRecords() {
        try {
            const { data, error } = await _supabase.from('records').select('*').eq('group_id', GROUP_ID).order('created_at', { ascending: false });
            if (error) throw error;

            allRecords = data;
            document.getElementById('statusDot').classList.add('online');
            document.getElementById('statusText').innerText = `已同步 (共 ${data.length} 条记录)`;
            
            updateNameList(); // 更新大类下拉提示

            const groups = {};
            data.forEach(item => {
                if (!groups[item.name]) groups[item.name] = [];
                groups[item.name].push(item);
            });
            renderUI(groups);
        } catch (err) {
            document.getElementById('statusText').innerText = '连接失败';
        }
    }

    function renderUI(groups) {
        const listEl = document.getElementById('recordList');
        if (Object.keys(groups).length === 0) {
            listEl.innerHTML = '<div style="text-align:center; color:#999; margin-top:50px;">暂无比价记录</div>';
            return;
        }

        let html = '';
        for (const [name, items] of Object.entries(groups)) {
            const minPrice = Math.min(...items.map(i => i.unit_price)).toFixed(2);
            const avgPrice = (items.reduce((sum, i) => sum + i.unit_price, 0) / items.length).toFixed(2);
            const unit = items[0].unit_label || '件';
            
            const isCollapsed = collapsedGroups[name] ? 'collapsed' : '';
            const listHidden = collapsedGroups[name] ? 'hidden' : '';

            html += `
            <div class="group-card">
                <div class="group-header" onclick="toggleGroup('${name}')">
                    <div class="group-title-area">
                        <div class="group-title">${name} <span style="font-size:12px; font-weight:normal; color:#999;">(${items.length}条)</span></div>
                        <div class="group-stats">
                            <span>史低: <span class="stats-highlight">¥${minPrice}</span>/${unit}</span>
                            <span>均价: ¥${avgPrice}/${unit}</span>
                        </div>
                    </div>
                    <div class="arrow ${isCollapsed}">▼</div>
                </div>
                
                <div class="item-list ${listHidden}">`;
                
            items.forEach(item => {
                const starActive = item.is_starred ? 'active' : '';
                const rowHighlight = item.is_starred ? 'is-starred' : '';
                const remarkHtml = item.remark ? `<div class="remark-text">📝 ${item.remark}</div>` : '';
                
                // 拼接规格行，如果有型号就展示
                const modelStr = item.model ? `型号: ${item.model} | ` : '';

                html += `
                    <div class="item-row ${rowHighlight}">
                        <div class="item-main">
                            <div class="channel-name">
                                <span class="star-icon ${starActive}" onclick="toggleStar(${item.id}, ${item.is_starred})">★</span>
                                ${item.channel || '未知渠道'}
                            </div>
                            <div class="sub-text">品牌: ${item.brand || '-'} | ${modelStr}规格: ${item.specs || '-'}</div>
                            <div class="sub-text">合计 ¥${item.total_price} (买了 ${item.qty}件)</div>
                            ${remarkHtml}
                        </div>
                        <div class="price-box">
                            <div class="unit-price">¥${item.unit_price} <span style="font-size:12px; color:#999;">/${item.unit_label || '件'}</span></div>
                            <div class="action-btns">
                                <button class="edit-btn" onclick="openEdit(${item.id})">编辑详情</button>
                            </div>
                        </div>
                    </div>`;
            });
            html += `</div></div>`;
        }
        listEl.innerHTML = html;
    }

    // --- 智能提示逻辑 (DataList) ---
    function updateNameList() {
        const names = [...new Set(allRecords.map(r => r.name).filter(n => n))];
        document.getElementById('name-list').innerHTML = names.map(n => `<option value="${n}">`).join('');
        
        // 顺便把所有出现过的渠道提取出来做提示
        const channels = [...new Set(allRecords.map(r => r.channel).filter(c => c))];
        document.getElementById('channel-list').innerHTML = channels.map(c => `<option value="${c}">`).join('');
    }

    // 当用户输入“一级分类”时，自动筛选出属于这个分类的“品牌”和“型号”
    function updateSuggestions() {
        const currentName = document.getElementById('f-name').value.trim();
        const brandList = document.getElementById('brand-list');
        const modelList = document.getElementById('model-list');
        brandList.innerHTML = '';
        modelList.innerHTML = '';

        if (!currentName) return;

        const brands = new Set();
        const models = new Set();

        allRecords.forEach(r => {
            if (r.name === currentName) {
                if (r.brand) brands.add(r.brand);
                if (r.model) models.add(r.model);
            }
        });

        brands.forEach(b => brandList.innerHTML += `<option value="${b}">`);
        models.forEach(m => modelList.innerHTML += `<option value="${m}">`);
    }

    function toggleGroup(name) {
        collapsedGroups[name] = !collapsedGroups[name];
        const groups = {};
        allRecords.forEach(item => {
            if (!groups[item.name]) groups[item.name] = [];
            groups[item.name].push(item);
        });
        renderUI(groups);
    }

    async function toggleStar(id, currentState) {
        const { error } = await _supabase.from('records').update({ is_starred: !currentState }).eq('id', id);
        if (error) alert('设置失败');
    }

    function openModal() {
        currentEditId = null;
        document.getElementById('modalTitle').innerText = '新增购买';
        document.querySelectorAll('.form-card input').forEach(input => input.value = '');
        document.getElementById('f-qty').value = '1';
        document.getElementById('f-specUnit').value = 'L';
        document.getElementById('btn-delete').style.display = 'none'; // 新增模式隐藏删除按钮
        updateSuggestions(); // 清空联动提示
        document.getElementById('formModal').classList.add('active');
    }

    function openEdit(id) {
        currentEditId = id;
        const item = allRecords.find(r => r.id === id);
        if(!item) return;

        document.getElementById('modalTitle').innerText = '修改记录';
        document.getElementById('f-name').value = item.name;
        document.getElementById('f-brand').value = item.brand || '';
        document.getElementById('f-model').value = item.model || ''; // 读取型号
        document.getElementById('f-channel').value = item.channel || '';
        document.getElementById('f-totalPrice').value = item.total_price;
        document.getElementById('f-remark').value = item.remark || '';
        
        let specNum = 1;
        let specUnit = item.unit_label || '件';
        if (item.specs) {
            const match = item.specs.match(/([0-9.]+)/);
            if (match) specNum = parseFloat(match[1]);
        }
        
        let qty = 1;
        if (item.unit_price > 0 && item.total_price > 0) {
            qty = Math.round((item.total_price / item.unit_price) / specNum) || 1;
        }

        document.getElementById('f-specNum').value = specNum;
        document.getElementById('f-specUnit').value = specUnit;
        document.getElementById('f-qty').value = qty;

        updateSuggestions(); // 根据当前 name 填充联动提示
        document.getElementById('btn-delete').style.display = 'block'; // 编辑模式显示删除按钮
        document.getElementById('formModal').classList.add('active');
    }

    function closeModal() { document.getElementById('formModal').classList.remove('active'); }

    async function handleSave() {
        const name = document.getElementById('f-name').value;
        const total = parseFloat(document.getElementById('f-totalPrice').value);
        const qty = parseInt(document.getElementById('f-qty').value) || 1;
        const specNum = parseFloat(document.getElementById('f-specNum').value) || 1;
        const specUnit = document.getElementById('f-specUnit').value;

        if (!name || isNaN(total)) return alert('【商品名称】和【总价】必须填写哦！');

        const unitPrice = parseFloat((total / (qty * specNum)).toFixed(2));
        const specsStr = `${specNum}${specUnit}`;

        const recordData = {
            name: name,
            brand: document.getElementById('f-brand').value,
            model: document.getElementById('f-model').value, // 存入型号
            specs: specsStr,
            total_price: total,
            unit_price: unitPrice,
            unit_label: specUnit,
            channel: document.getElementById('f-channel').value,
            remark: document.getElementById('f-remark').value,
            group_id: GROUP_ID
        };

        if (currentEditId) {
            await _supabase.from('records').update(recordData).eq('id', currentEditId);
        } else {
            await _supabase.from('records').insert([recordData]);
        }

        closeModal();
        fetchRecords(); 
    }

    // 将删除函数移到内部，由删除按钮调用
    async function deleteRecord() {
        if (!currentEditId) return;
        if (!confirm('确定要永久删除这条记录吗？\n删除后不可恢复！')) return;
        
        const { error } = await _supabase.from('records').delete().eq('id', currentEditId);
        if (error) {
            alert('删除失败: ' + error.message);
        } else {
            closeModal();
            fetchRecords();
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        fetchRecords();
        _supabase.channel('any').on('postgres_changes', { event: '*', table: 'records' }, fetchRecords).subscribe();
    });
</script>

</body>
</html>
