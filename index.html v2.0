<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>比价程序-同步版</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            --bg: #F5EFE6; --nav: #241408; --accent: #7A4F2D;
            --text: #2E1A0A; --sub: #907060; --border: #E2D0BC; --white: #FFFCF8;
        }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { 
            margin: 0; background: var(--bg); color: var(--text); 
            font-family: -apple-system, sans-serif; 
            display: flex; flex-direction: column; height: 100vh;
        }

        /* 顶部 - 增加安全区域适配 */
        header { background: var(--nav); padding: 50px 20px 20px; color: white; flex-shrink: 0; }
        .nav-sub { font-size: 10px; letter-spacing: 2px; color: #C49A6C; }
        .nav-main-row { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 5px; }
        .nav-title { font-size: 24px; font-weight: bold; }
        .nav-stats b { font-size: 20px; color: #C49A6C; }

        /* 列表区 - 保证滚动顺畅 */
        main { flex: 1; overflow-y: auto; padding: 15px; -webkit-overflow-scrolling: touch; }
        .group-card { background: var(--white); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 12px; }
        .group-header { padding: 15px; display: flex; justify-content: space-between; align-items: center; }
        .group-title { font-size: 16px; font-weight: bold; }

        /* 明细项 - 手机端紧凑排版 */
        .sub-list { background: #fff; border-top: 1px solid #f0e6da; }
        .sub-item { padding: 12px 15px; display: flex; border-bottom: 1px solid #f0e6da; }
        .dot { width: 8px; height: 8px; background: #4A7A50; border-radius: 50%; margin: 6px 10px 0 0; }
        .sub-content { flex: 1; }
        .row-top { display: flex; justify-content: space-between; font-weight: bold; }
        .price-val { color: var(--text); }
        .row-mid { font-size: 12px; color: var(--sub); margin: 4px 0; }
        .row-bottom { display: flex; justify-content: space-between; font-size: 12px; color: var(--sub); margin-top: 4px; }
        .del-btn { color: #C06840; text-decoration: underline; padding: 5px; }

        /* 弹窗表单 - 手机全屏优化 */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 100; align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .form-card { background: var(--white); width: 92%; padding: 20px; border-radius: 12px; }
        input { width: 100%; background: var(--bg); border: 1px solid var(--border); padding: 12px; border-radius: 6px; margin-bottom: 10px; font-size: 16px; -webkit-appearance: none; }
        
        /* 底部按钮 */
        footer { padding: 15px 20px 30px; background: var(--bg); border-top: 1px solid var(--border); }
        .add-btn { background: var(--accent); color: white; width: 100%; padding: 15px; border-radius: 8px; font-size: 16px; font-weight: bold; border: none; }
    </style>
</head>
<body>

<header>
    <div class="nav-sub">PRICE CHECKER</div>
    <div class="nav-main-row">
        <div class="nav-title">比价程序</div>
        <div class="nav-stats"><b id="totalCount">0</b>条</div>
    </div>
</header>

<main id="recordList"></main>

<footer>
    <button class="add-btn" onclick="openModal()">＋ 新增购买记录</button>
</footer>

<div class="modal" id="formModal">
    <div class="form-card">
        <div style="font-weight:bold; margin-bottom:15px;">新增记录</div>
        <input type="text" id="f-name" placeholder="商品名称">
        <input type="text" id="f-brand" placeholder="品牌">
        <input type="text" id="f-specs" placeholder="规格 (如 5L)">
        <div style="display:flex; gap:10px;">
            <input type="number" id="f-totalPrice" placeholder="总价">
            <input type="number" id="f-qty" placeholder="件数" value="1">
        </div>
        <input type="text" id="f-channel" placeholder="渠道/平台">
        <div style="display:flex; gap:10px; margin-top:10px;">
            <button style="flex:1; background:#eee; padding:12px; border-radius:6px; border:none;" onclick="closeModal()">取消</button>
            <button style="flex:1; background:var(--accent); color:white; padding:12px; border-radius:6px; border:none;" onclick="handleSave()">同步保存</button>
        </div>
    </div>
</div>

<script>
    // --- 配置云端 ---
    const SUPABASE_URL = 'https://csktstukwmuitvsjjzwd.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNza3RzdHVrd211aXR2c2pqendkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4NTcwNzYsImV4cCI6MjA5MDQzMzA3Nn0.fc-7q3Xmr1MtZR_NdiIxQ4f3QtbtLn_T1smJM8_INlE';
    const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    const GROUP_ID = 'family_share_2026';

    let expandedGroups = {};

    async function fetchRecords() {
        const { data, error } = await _supabase.from('records').select('*').eq('group_id', GROUP_ID).order('created_at', { ascending: false });
        if (error) return;
        
        document.getElementById('totalCount').innerText = data.length;
        const groups = {};
        data.forEach(item => {
            if (!groups[item.name]) groups[item.name] = { name: item.name, list: [] };
            groups[item.name].list.push(item);
        });
        render(Object.values(groups));
    }

    function render(groups) {
        const container = document.getElementById('recordList');
        container.innerHTML = groups.length ? '' : '<div style="text-align:center; color:#999; margin-top:40px;">云端暂无数据</div>';
        
        groups.forEach(g => {
            const isExp = expandedGroups[g.name];
            const div = document.createElement('div');
            div.className = 'group-card';
            div.innerHTML = `
                <div class="group-header" onclick="toggle('${g.name}')">
                    <span class="group-title">${g.name}</span>
                    <span style="font-size:12px; color:#ccc;">${isExp ? '▲' : '▼'}</span>
                </div>
                ${isExp ? `<div class="sub-list">${g.list.map(i => `
                    <div class="sub-item">
                        <div class="dot"></div>
                        <div class="sub-content">
                            <div class="row-top"><span>${i.channel}</span><span class="price-val">¥${i.unit_price}<small style="font-size:10px;font-weight:normal">/${i.unit_label}</small></span></div>
                            <div class="row-mid">品牌:${i.brand || '-'} | 规格:${i.specs || '-'}</div>
                            <div class="row-bottom"><span>${i.qty}件 · 共¥${i.total_price}</span><span class="del-btn" onclick="del(${i.id})">删除</span></div>
                        </div>
                    </div>`).join('')}</div>` : ''}`;
            container.appendChild(div);
        });
    }

    function toggle(n) { expandedGroups[n] = !expandedGroups[n]; fetchRecords(); }
    function openModal() { document.getElementById('formModal').classList.add('active'); }
    function closeModal() { document.getElementById('formModal').classList.remove('active'); }

    async function handleSave() {
        const name = document.getElementById('f-name').value;
        const price = parseFloat(document.getElementById('f-totalPrice').value);
        const qty = parseInt(document.getElementById('f-qty').value) || 1;
        if (!name || isNaN(price)) return alert('请填写名称和价格');

        const { error } = await _supabase.from('records').insert([{
            name, brand: document.getElementById('f-brand').value,
            specs: document.getElementById('f-specs').value,
            total_price: price, unit_price: parseFloat((price/qty).toFixed(2)),
            unit_label: '件', channel: document.getElementById('f-channel').value,
            group_id: GROUP_ID
        }]);

        if (error) alert('保存失败');
        else { closeModal(); resetForm(); fetchRecords(); }
    }

    async function del(id) { if(confirm('确认删除？')) { await _supabase.from('records').delete().eq('id', id); fetchRecords(); } }
    function resetForm() { document.querySelectorAll('input').forEach(i => i.value = (i.id==='f-qty'?'1':'')); }

    document.addEventListener('DOMContentLoaded', fetchRecords);
    _supabase.channel('any').on('postgres_changes', { event: '*', table: 'records' }, fetchRecords).subscribe();
</script>
</body>
</html>
